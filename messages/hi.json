    "subheading": "\u0939\u092e\u093e\u0930\u0940 \u092b\u0948\u0915\u094d\u091f\u094d\u0930\u0940 \u0938\u0947 \u0928\u093f\u0915\u0932\u0928\u0947 \u0935\u093e\u0932\u093e \u0939\u0930 \u0921\u093e\u0908 \u0924\u0940\u0928 \u0935\u093f\u092d\u093e\u0917\u094b\u0902 \u0938\u0947 \u0917\u0941\u091c\u0930\u0924\u093e \u0939\u0948 \u2014 \u0939\u0930 \u090f\u0915 \u0905\u092a\u0928\u0947 \u0906\u092a \u092e\u0947\u0902 \u090f\u0915 \u0936\u093f\u0932\u094d\u092a\u0964",
