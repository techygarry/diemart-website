  "about": {
    "label": "\u0939\u092e\u093e\u0930\u0940 \u0915\u0939\u093e\u0928\u0940",
    "heading": "\u0927\u093e\u0924\u0941 \u0915\u0947 \u092a\u0940\u091b\u0947 \u0915\u093e \u0906\u0926\u092e\u0940",
    "p1": "Die Mart \u0915\u094b \u090f\u0932\u094d\u092f\u093e\u0938 \u0928\u093e\u0917\u0935\u0921\u094d\u0930\u093f\u092f\u093e \u0928\u0947 \u092c\u0928\u093e\u092f\u093e \u2014 \u090f\u0915 \u0910\u0938\u093e \u0906\u0926\u092e\u0940 \u091c\u093f\u0938\u0928\u0947 \u0936\u0942\u0928\u094d\u092f \u0938\u0947 \u0936\u0941\u0930\u0942\u0906\u0924 \u0915\u0940\u0964 \u0938\u0924\u094d\u0930\u0939 \u0938\u093e\u0932 \u0915\u0940 \u0909\u092e\u094d\u0930 \u092e\u0947\u0902, \u0935\u0939 \u0915\u0941\u0930\u094d\u0932\u093e \u0915\u0940 \u091d\u0941\u0917\u094d\u0917\u093f\u092f\u094b\u0902 \u0938\u0947 \u092c\u093f\u0928\u093e \u0915\u093f\u0938\u0940 \u0935\u093f\u0930\u093e\u0938\u0924 \u092f\u093e \u0935\u094d\u092f\u093e\u092a\u093e\u0930 \u0915\u0947 \u0928\u093f\u0915\u0932\u0947\u0964 \u0935\u0939 \u0939\u0930 \u0926\u093f\u0928 \u0924\u093e\u0930\u093e\u092a\u0941\u0930 \u091c\u093e\u0928\u0947 \u0935\u093e\u0932\u0940 \u091f\u094d\u0930\u0947\u0928 \u092a\u0915\u0921\u093c\u0924\u0947, \u092e\u0941\u0902\u092c\u0908 \u0915\u0947 \u091c\u093c\u0935\u0947\u0930\u0940 \u092c\u093e\u091c\u093c\u093e\u0930 \u0915\u0940 \u0915\u093e\u0930\u094d\u092f\u0936\u093e\u0932\u093e\u0913\u0902 \u092e\u0947\u0902 \u091c\u094d\u0935\u0947\u0932\u0930\u0940 \u0921\u093e\u0908 \u092c\u0928\u093e\u0928\u0947 \u0915\u0947 \u0930\u093e\u091c\u093c \u0938\u0940\u0916\u0947\u0964",
    "p2": "\u0935\u0930\u094d\u0937\u094b\u0902 \u0924\u0915, \u0935\u0939 \u0924\u093e\u0930\u093e\u092a\u0941\u0930 \u0938\u0947 \u092e\u0941\u0902\u092c\u0908 \u0924\u0915 \u091f\u094d\u0930\u0947\u0928 \u0938\u0947 \u0924\u0948\u092f\u093e\u0930 \u0921\u093e\u0908 \u0932\u0947 \u091c\u093e\u0924\u0947 \u0925\u0947 \u2014 \u0905\u092a\u0928\u0947 \u0935\u091a\u0928 \u092a\u0930 \u0915\u093f \u0915\u093e\u092e \u092a\u0930\u092b\u0947\u0915\u094d\u091f \u0939\u094b\u0917\u093e\u0964 \u0914\u0930 \u0939\u092e\u0947\u0936\u093e \u0939\u094b\u0924\u093e \u0925\u093e\u0964",
    "p3": "\u0924\u0940\u0938 \u0938\u093e\u0932 \u092c\u093e\u0926, Die Mart \u0924\u0940\u0928 \u092b\u0948\u0915\u094d\u091f\u094d\u0930\u093f\u092f\u094b\u0902 \u0938\u0947 \u0938\u0902\u091a\u093e\u0932\u093f\u0924 \u0939\u094b\u0924\u093e \u0939\u0948, \u0924\u093e\u0930\u093e\u092a\u0941\u0930 \u0938\u0947 \u0927\u093e\u0928\u093e\u0909 \u0914\u0930 \u092a\u0942\u0930\u0947 \u092d\u093e\u0930\u0924 \u092e\u0947\u0902 \u0917\u094d\u0930\u093e\u0939\u0915\u094b\u0902 \u0915\u094b \u0938\u0947\u0935\u093e \u0926\u0947\u0924\u093e \u0939\u0948, \u0914\u0930 3,600 \u0938\u0947 \u0905\u0927\u093f\u0915 \u0921\u093e\u0908 \u0915\u093e \u0921\u093f\u091c\u093c\u093e\u0907\u0928 \u0906\u0930\u094d\u0915\u093e\u0907\u0935 \u0939\u0948\u0964",
    "quote": "\u201c\u092e\u0948\u0902\u0928\u0947 \u0936\u0942\u0928\u094d\u092f \u0938\u0947 \u0936\u0941\u0930\u0942\u0906\u0924 \u0915\u0940\u0964 \u0938\u092c\u0938\u0947 \u0905\u091a\u094d\u091b\u0947 \u0932\u094b\u0917\u094b\u0902 \u0938\u0947 \u0938\u0940\u0916\u093e\u0964 \u091c\u094b \u092e\u093e\u0928\u093e \u0909\u0938\u0947 \u092c\u0928\u093e\u092f\u093e\u0964 \u0939\u0930 \u0917\u094d\u0930\u093e\u0939\u0915 \u091c\u094b \u0939\u092e \u092a\u0930 \u092d\u0930\u094b\u0938\u093e \u0915\u0930\u0924\u093e \u0939\u0948 \u2014 \u0935\u0939 \u092d\u0930\u094b\u0938\u093e \u0939\u0940 \u0938\u092c\u0938\u0947 \u092c\u0921\u093c\u093e \u0907\u0928\u093e\u092e \u0939\u0948\u0964\u201d \u2014 \u090f\u0932\u094d\u092f\u093e\u0938 \u0928\u093e\u0917\u0935\u0921\u094d\u0930\u093f\u092f\u093e, \u0938\u0902\u0938\u094d\u0925\u093e\u092a\u0915",
    "closing": "\u0909\u0928\u0915\u0947 \u092c\u0947\u091f\u0947 \u0939\u0941\u0938\u0948\u0928 \u0935\u094d\u092f\u0935\u0938\u093e\u092f \u0915\u094b \u0906\u0917\u0947 \u0932\u0947 \u091c\u093e \u0930\u0939\u0947 \u0939\u0948\u0902 \u2014 3D \u0921\u093f\u091c\u093c\u093e\u0907\u0928, AI-\u0938\u0902\u091a\u093e\u0932\u093f\u0924 \u0915\u0948\u091f\u0932\u0949\u0917 \u092a\u094d\u0930\u0923\u093e\u0932\u0940, \u0914\u0930 \u090f\u0915 \u0928\u0908 \u092a\u0940\u0922\u093c\u0940 \u0915\u0940 \u0926\u0943\u0937\u094d\u091f\u093f \u0915\u094b \u0909\u0928\u0915\u0947 \u092a\u093f\u0924\u093e \u0926\u094d\u0935\u093e\u0930\u093e \u0928\u093f\u0930\u094d\u092e\u093f\u0924 \u0936\u093f\u0932\u094d\u092a \u092e\u0947\u0902 \u0932\u093e \u0930\u0939\u0947 \u0939\u0948\u0902\u0964"
  },
