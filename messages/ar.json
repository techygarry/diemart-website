    "beat_origin_title": "\u0627\u0644\u0628\u062f\u0627\u064a\u0629",
    "beat_origin": "\u0628\u062f\u0623 \u0625\u0644\u064a\u0627\u0633 \u0646\u0627\u063a\u0641\u0627\u062f\u0631\u064a\u0627 \u0631\u062d\u0644\u062a\u0647 \u0641\u064a \u0639\u0627\u0645 1980. \u0645\u0646 \u0623\u062d\u064a\u0627\u0621 \u0643\u0648\u0631\u0644\u0627 \u0627\u0644\u0641\u0642\u064a\u0631\u0629 \u0625\u0644\u0649 \u0648\u0631\u0634 \u0634\u064a\u0646\u0634\u0627\u0646\u064a \u2014 \u0631\u062c\u0644 \u0628\u062f\u0623 \u0645\u0646 \u0644\u0627 \u0634\u064a\u0621 \u0648\u0628\u0646\u0649 \u0643\u0644 \u0634\u064a\u0621.",
    "beat_craft_title": "\u0627\u0644\u062d\u0631\u0641\u0629",
    "beat_craft": "\u0622\u0644\u0629 \u0648\u0627\u062d\u062f\u0629. \u0648\u0639\u062f \u0648\u0627\u062d\u062f. \u062b\u0644\u0627\u062b\u0629 \u0645\u0635\u0627\u0646\u0639. 100+ \u062d\u0631\u0641\u064a. \u0643\u0644 \u0642\u0627\u0644\u0628 \u064a\u062e\u0631\u062c \u0645\u0646 \u0623\u064a\u062f\u064a\u0646\u0627 \u064a\u062d\u0645\u0644 \u062b\u0642\u0644 \u0623\u0631\u0628\u0639\u0629 \u0639\u0642\u0648\u062f \u0645\u0646 \u0627\u0644\u062f\u0642\u0629.",
    "beat_die_title": "\u0627\u0644\u0642\u0627\u0644\u0628",
    "beat_die": "\u0645\u0641\u0643\u0643 \u0628\u0627\u0644\u0643\u0627\u0645\u0644. \u0643\u0644 \u0645\u0643\u0648\u0646 \u0638\u0627\u0647\u0631 \u2014 \u0627\u0644\u0644\u0648\u062d\u0629 \u0627\u0644\u0623\u0633\u0627\u0633\u064a\u0629\u060c \u0645\u0642\u0628\u0636 \u0627\u0644\u0646\u0642\u0634\u060c \u0645\u0642\u0628\u0636 \u0627\u0644\u0642\u0637\u0639\u060c \u0627\u0644\u062a\u062c\u0648\u064a\u0641\u060c \u0627\u0644\u0628\u0631\u0627\u063a\u064a. 3,600+ \u062a\u0635\u0645\u064a\u0645.",
    "beat_revolution_title": "\u0627\u0644\u062b\u0648\u0631\u0629",
    "beat_revolution": "\u0641\u064a \u0639\u0627\u0645 2022\u060c \u0623\u0633\u0633 \u062d\u0633\u064a\u0646 \u0646\u0627\u063a\u0641\u0627\u062f\u0631\u064a\u0627 Die Mart \u0643\u0639\u0644\u0627\u0645\u0629 \u062a\u062c\u0627\u0631\u064a\u0629. \u0643\u062a\u0627\u0644\u0648\u062c\u0627\u062a \u0645\u062f\u0639\u0648\u0645\u0629 \u0628\u0627\u0644\u0630\u0643\u0627\u0621 \u0627\u0644\u0627\u0635\u0637\u0646\u0627\u0639\u064a. \u062a\u062a\u0628\u0639 \u0631\u0642\u0645\u064a.",
    "beat_world_title": "\u0627\u0644\u0639\u0627\u0644\u0645",
    "beat_world": "\u0627\u0644\u0642\u0627\u0644\u0628 \u0623\u0639\u064a\u062f \u062a\u062c\u0645\u064a\u0639\u0647. \u0645\u062b\u0627\u0644\u064a. \u062c\u0627\u0647\u0632. \u0645\u0646 \u0634\u064a\u0646\u0634\u0627\u0646\u064a \u0625\u0644\u0649 \u0627\u0644\u0639\u0627\u0644\u0645 \u2014 \u0627\u0644\u0647\u0646\u062f\u060c \u0627\u0644\u0634\u0631\u0642 \u0627\u0644\u0623\u0648\u0633\u0637\u060c \u0623\u0648\u0631\u0648\u0628\u0627. \u0642\u0627\u0644\u0628\u0643 \u0627\u0644\u0642\u0627\u062f\u0645 \u064a\u0628\u062f\u0623 \u0645\u0646 \u0647\u0646\u0627.",
