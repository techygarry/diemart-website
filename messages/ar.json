    "step2_desc": "\u064a\u062d\u0633\u0628 \u0627\u0644\u0645\u0628\u0631\u0645\u062c \u062a\u0641\u0627\u0648\u062a\u0627\u062a \u0627\u0644\u062e\u0644\u0648\u0635 \u0627\u0644\u062f\u0642\u064a\u0642\u0629. \u0645\u0648\u0627\u0641\u0642\u0629 \u0627\u0644\u0639\u0645\u064a\u0644 \u0639\u0628\u0631 \u0648\u0627\u062a\u0633\u0627\u0628.",
