    "embossing_title": "\u0627\u0644\u0646\u0642\u0634 \u0627\u0644\u0628\u0627\u0631\u0632",
    "embossing_desc": "\u062b\u0644\u0627\u062b \u062a\u062e\u0635\u0635\u0627\u062a \u0641\u064a \u0627\u0644\u0646\u0642\u0634 \u062a\u062d\u062a \u0633\u0642\u0641 \u0648\u0627\u062d\u062f. \u0646\u0642\u0634 \u064a\u062f\u0648\u064a \u0644\u0644\u062a\u0635\u0627\u0645\u064a\u0645 \u0627\u0644\u0639\u0627\u062f\u064a\u0629. \u0622\u0644\u0629 \u0627\u0644\u0646\u0642\u0634 \u0644\u0644\u0639\u0645\u0644 \u0627\u0644\u0645\u0639\u0642\u062f. \u0646\u0642\u0634 \u0628\u0627\u0644\u0644\u064a\u0632\u0631 \u0644\u0644\u0623\u0646\u0645\u0627\u0637 \u0627\u0644\u062f\u0642\u064a\u0642\u0629.",
    "embossing_tag": "\u064a\u062f\u0648\u064a \u00b7 \u0622\u0644\u0629 \u0627\u0644\u0646\u0642\u0634 \u00b7 \u0644\u064a\u0632\u0631",
    "quality_title": "\u0627\u062e\u062a\u0628\u0627\u0631 \u0627\u0644\u062c\u0648\u062f\u0629",
    "quality_desc": "\u0643\u0644 \u0642\u0627\u0644\u0628 \u064a\u062e\u0636\u0639 \u0644\u0644\u0636\u063a\u0637 \u0641\u0639\u0644\u064a\u064b\u0627 \u0642\u0628\u0644 \u0627\u0644\u0634\u062d\u0646. \u062b\u0644\u0627\u062b\u0629 \u0627\u062e\u062a\u0628\u0627\u0631\u0627\u062a: \u0627\u0644\u0637\u0628\u0639\u0629 \u2014 \u0627\u0644\u0645\u062d\u0627\u0630\u0627\u0629 \u2014 \u0639\u062f\u0645 \u0627\u0644\u0643\u0633\u0631.",
