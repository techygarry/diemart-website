  "about": {
    "label": "\u0642\u0635\u062a\u0646\u0627",
    "heading": "\u0627\u0644\u0631\u062c\u0644 \u0648\u0631\u0627\u0621 \u0627\u0644\u0645\u0639\u062f\u0646",
    "p1": "\u0628\u0646\u0649 \u0625\u0644\u064a\u0627\u0633 \u0646\u0627\u063a\u0641\u0627\u062f\u0631\u064a\u0627 Die Mart \u2014 \u0631\u062c\u0644 \u0628\u062f\u0623 \u0645\u0646 \u0644\u0627 \u0634\u064a\u0621. \u0641\u064a \u0627\u0644\u0633\u0627\u0628\u0639\u0629 \u0639\u0634\u0631\u0629 \u0645\u0646 \u0639\u0645\u0631\u0647\u060c \u063a\u0627\u062f\u0631 \u0623\u062d\u064a\u0627\u0621 \u0643\u0648\u0631\u0644\u0627 \u0627\u0644\u0641\u0642\u064a\u0631\u0629 \u0628\u062f\u0648\u0646 \u0645\u064a\u0631\u0627\u062b \u0623\u0648 \u062d\u0631\u0641\u0629.",
    "p2": "\u0644\u0633\u0646\u0648\u0627\u062a\u060c \u0643\u0627\u0646 \u064a\u062d\u0645\u0644 \u0627\u0644\u0642\u0648\u0627\u0644\u0628 \u0627\u0644\u062c\u0627\u0647\u0632\u0629 \u0628\u0646\u0641\u0633\u0647 \u0645\u0646 \u062a\u0627\u0631\u0627\u0628\u0648\u0631 \u0625\u0644\u0649 \u0645\u0648\u0645\u0628\u0627\u064a \u0628\u0627\u0644\u0642\u0637\u0627\u0631 \u2014 \u0639\u0644\u0649 \u0648\u0639\u062f\u0647 \u0628\u0623\u0646 \u0627\u0644\u0639\u0645\u0644 \u0633\u064a\u0643\u0648\u0646 \u0645\u062b\u0627\u0644\u064a\u064b\u0627. \u0648\u0643\u0627\u0646 \u0643\u0630\u0644\u0643 \u062f\u0627\u0626\u0645\u064b\u0627.",
    "p3": "\u0628\u0639\u062f \u062b\u0644\u0627\u062b\u064a\u0646 \u0639\u0627\u0645\u064b\u0627\u060c \u062a\u062f\u064a\u0631 Die Mart \u062b\u0644\u0627\u062b\u0629 \u0645\u0635\u0627\u0646\u0639 \u0648\u062a\u062e\u062f\u0645 \u0639\u0645\u0644\u0627\u0621 \u0639\u0628\u0631 \u0627\u0644\u0647\u0646\u062f \u0628\u0623\u0631\u0634\u064a\u0641 \u064a\u0636\u0645 \u0623\u0643\u062b\u0631 \u0645\u0646 3,600 \u0642\u0627\u0644\u0628.",
    "quote": "\u00ab\u0628\u062f\u0623\u062a \u0645\u0646 \u0644\u0627 \u0634\u064a\u0621. \u062a\u0639\u0644\u0645\u062a \u0645\u0646 \u0627\u0644\u0623\u0641\u0636\u0644. \u0628\u0646\u064a\u062a \u0645\u0627 \u0622\u0645\u0646\u062a \u0628\u0647. \u0643\u0644 \u0639\u0645\u064a\u0644 \u064a\u062b\u0642 \u0628\u0646\u0627 \u2014 \u0647\u0630\u0647 \u0627\u0644\u062b\u0642\u0629 \u0647\u064a \u0627\u0644\u0645\u0643\u0627\u0641\u0623\u0629 \u0627\u0644\u0648\u062d\u064a\u062f\u0629 \u0627\u0644\u0645\u0647\u0645\u0629.\u00bb \u2014 \u0625\u0644\u064a\u0627\u0633 \u0646\u0627\u063a\u0641\u0627\u062f\u0631\u064a\u0627\u060c \u0627\u0644\u0645\u0624\u0633\u0633",
    "closing": "\u0627\u0628\u0646\u0647 \u062d\u0633\u064a\u0646 \u064a\u0642\u0648\u062f \u0627\u0644\u0639\u0645\u0644 \u0625\u0644\u0649 \u0627\u0644\u0623\u0645\u0627\u0645 \u2014 \u0628\u0627\u0644\u062a\u0635\u0645\u064a\u0645 \u062b\u0644\u0627\u062b\u064a \u0627\u0644\u0623\u0628\u0639\u0627\u062f \u0648\u0623\u0646\u0638\u0645\u0629 \u0627\u0644\u0643\u062a\u0627\u0644\u0648\u062c \u0627\u0644\u0645\u062f\u0639\u0648\u0645\u0629 \u0628\u0627\u0644\u0630\u0643\u0627\u0621 \u0627\u0644\u0627\u0635\u0637\u0646\u0627\u0639\u064a."
